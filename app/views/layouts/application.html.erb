<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Softwaredonarsangre" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <body style="background-color: #f5f5f5; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">

    <div id="flash-message" 
        class="flash-popup <%= flash[:alert] ? 'alert' : (flash[:notice] ? 'notice' : '') %>" 
        style="<%= flash.any? ? '' : 'display: none;' %>">
      <%= flash[:alert] || flash[:notice] %>
    </div>

    <%= yield %>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const flash = document.getElementById("flash-message");
        if (flash && flash.textContent.trim() !== '') {
          setTimeout(() => {
            flash.classList.add("hide");
          }, 6000);
        }
      });
    </script>

    <footer style="background: #1a1a1a; color: #fff; text-align: center; padding: 20px 10px; margin-top: 50px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
      <p style="margin: 5px 0;">&copy; 2025 <strong>Tuguy Porã</strong>. Todos los derechos reservados.</p>
      <p style="margin: 5px 0;">
        <a href="/informacion" style="color: #f8f9fa; text-decoration: underline;">Información y requisitos</a>
      </p>
    </footer>
  </body>
</html>