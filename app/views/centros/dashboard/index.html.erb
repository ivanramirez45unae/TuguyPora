<%= render 'shared/navbar' %>

<h1 style="text-align: center; color: #c00000; margin-bottom: 24px;">📋 Lista de Postulaciones</h1>

<table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; box-shadow: 0 0 10px rgba(0,0,0,0.1);">
  <thead style="background-color: #ffd2bd;">
    <tr style="text-align: left;">
      <th style="padding: 12px; border-bottom: 2px solid #ccc;">ID</th>
      <th style="padding: 12px; border-bottom: 2px solid #ccc;">Donante</th>
      <th style="padding: 12px; border-bottom: 2px solid #ccc;">Ubicación</th>
      <th style="padding: 12px; border-bottom: 2px solid #ccc;">Fecha tentativa</th>
      <th style="padding: 12px; border-bottom: 2px solid #ccc;">Hora tentativa</th>
      <th style="padding: 12px; border-bottom: 2px solid #ccc;">Solicitud vinculada</th>
      <th style="padding: 12px; border-bottom: 2px solid #ccc;">Estado</th>
    </tr>
  </thead>

  <tbody>
    <% @postulaciones.each do |p| %>
      <% next unless current_user.centro? && p.estado == 'P' %>
      <tr class="clickable-row"
          data-href="<%= new_postulacion_donacion_path(p) %>"
          style="cursor: pointer; transition: background 0.2s ease;">
        <td style="padding: 10px;"><%= p.id %></td>
        <td style="padding: 10px;"><%= User.find(p.user_id).nombre rescue "Sin datos" %></td>
        <td style="padding: 10px;"><%= Ubicacion.find(p.ubicacion_id).nombre rescue "Desconocida" %></td>
        <td style="padding: 10px;"><%= p.fecha_tentativa.strftime("%d/%m/%Y") %></td>
        <td style="padding: 10px;"><%= p.hora_tentativa.strftime("%H:%M") %></td>
        <td style="padding: 10px;">
          <% if p.solicitud_id.present? %>
            <%= link_to "Solicitud ##{p.solicitud_id}", solicitud_path(p.solicitud_id), style: "color: #c00000;" %>
          <% else %>
            <em>—</em>
          <% end %>
        </td>
        <td style="padding: 10px;">
          <% estado = { "P" => "Pendiente", "C" => "Confirmada", "R" => "Rechazada" } %>
          <span style="color: #444;"><%= estado[p.estado] || p.estado %></span>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<script>
  document.querySelectorAll('.clickable-row').forEach(row => {
    row.addEventListener('click', () => {
      const url = row.getAttribute('data-href');
      if (url) window.location.href = url;
    });

    row.addEventListener('mouseover', () => {
      row.style.backgroundColor = '#fff2ef';
    });
    row.addEventListener('mouseout', () => {
      row.style.backgroundColor = 'white';
    });
  });
</script>

