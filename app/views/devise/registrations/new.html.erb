<!-- App title -->
<h1 class="app-title">Tuguy Porã - Itapúa</h1>

<h2 class="title">Registrarse</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: {class: "form-card"}) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="input-group">
    <%= f.label :email, "Correo electrónico", class: "input-label" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-field", placeholder: "ejemplo@correo.com" %>
  </div>

  <div class="input-group">
    <%= f.label :password, "Contraseña", class: "input-label" %>
    <% if @minimum_password_length %>
      <em class="password-info">(<%= @minimum_password_length %> caracteres mínimo)</em>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password", class: "input-field", placeholder: "Tu contraseña" %>
  </div>

  <div class="input-group">
    <%= f.label :password_confirmation, "Confirmar contraseña", class: "input-label" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input-field", placeholder: "Repite tu contraseña" %>
  </div>

  <hr class="separator">

  <div class="input-group">
    <%= f.label :nombre, "Nombre completo", class: "input-label" %>
    <%= f.text_field :nombre, class: "input-field", placeholder: "Tu nombre" %>
  </div>

  <div class="input-group">
    <%= f.label :nombredeusuario, "Nombre de usuario", class: "input-label" %>
    <%= f.text_field :nombredeusuario, class: "input-field", placeholder: "Tu usuario" %>
  </div>

  <div class="input-group">
    <%= f.label :num_telefono, "Número de Teléfono", class: "input-label" %>
    <%= f.text_field :num_telefono, class: "input-field", placeholder: "09XX XXX XXX" %>
  </div>

  <div class="input-group">
    <%= f.label :fec_nacimiento, "Fecha de Nacimiento", class: "input-label" %>
    <%= f.date_field :fec_nacimiento, class: "input-field" %>
  </div>

  <div class="input-group">
    <%= f.label :direccion, "Dirección", class: "input-label" %>
    <%= f.text_field :direccion, class: "input-field", placeholder: "Tu dirección" %>
  </div>

  <div class="input-group">
    <%= f.label :genero, "Género", class: "input-label" %>
    <%= f.select :genero, ["Masculino", "Femenino", "Otro"], prompt: "Seleccione un género", class: "input-field" %>
  </div>

  <button type="submit" class="btn-primary">Registrarse</button>
<% end %>

<div class="links" style="margin-top: 1rem; text-align: center;">
  <p><%= link_to "¿Ya tienes una cuenta? Inicia sesión", new_user_session_path, class: "link-text" %></p>
</div>

<style>
  body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #a1201f 0%, #c8382d 100%);
    margin: 0; padding: 0;
    display: flex; justify-content: center; align-items: center; min-height: 100vh;
    flex-direction: column;
  }
  .app-title {
    font-weight: 900;
    font-size: 3rem;
    color: #ffffffff;
    margin-bottom: 1.5rem;
    text-align: center;
    letter-spacing: 2px;
    user-select: none;
  }
  .form-card {
    background: white;
    padding: 3rem 2rem 2rem;
    border-radius: 20px;
    width: 420px;
    box-shadow:
      0 15px 25px rgba(161, 32, 31, 0.3),
      0 8px 12px rgba(0, 0, 0, 0.12);
  }
  .title {
    text-align: center;
    font-weight: 800;
    font-size: 2.5rem;
    color: #ffffff;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }
  .input-group {
    margin-bottom: 1.3rem;
    position: relative;
  }
  .input-label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.4rem;
    color: #7a0e0c;
    font-size: 0.9rem;
  }
  .password-info {
    color: #b94a48;
    font-size: 0.85rem;
    margin-left: 0.3rem;
    font-style: italic;
  }
  .input-field {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid #e6b8b6;
    border-radius: 12px;
    font-size: 1rem;
    transition: all 0.3s ease;
    font-weight: 500;
    box-sizing: border-box;
  }
  .input-field:focus {
    outline: none;
    border-color: #c8382d;
    box-shadow: 0 0 10px #c8382daa;
    background-color: #fff0f0;
  }
  .separator {
    margin: 1.5rem 0;
    border: none;
    border-top: 2px solid #f0b0ad;
  }
  .btn-primary {
    width: 100%;
    background: #c8382d;
    color: white;
    font-weight: 700;
    font-size: 1.2rem;
    padding: 0.75rem;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    transition: background 0.3s ease;
    box-shadow: 0 6px 14px rgba(200, 56, 45, 0.7);
  }
  .btn-primary:hover {
    background: #7a0e0c;
    box-shadow: 0 8px 18px rgba(122, 14, 12, 0.9);
  }
  .alert-error {
    background: #fbeaea;
    border: 1px solid #c8382d;
    color: #7a0e0c;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 12px;
  }
  .links {
    text-align: center;
  }
  .link-text {
    color: #ffffff;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .link-text:hover {
    color: #f3cac7ff;
  }
</style>
