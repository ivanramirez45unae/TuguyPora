<div class="login-background"></div>

<div class="login-wrapper">

  <div class="login-card">

    <div class="logo-container">
      <%= image_tag "TuguyPora_logo.png", class: "logo-img" %>
    </div>

    <h2>Restaurar contraseña</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

        <div class="input-group">
          <label class="input-label">Correo electrónico</label>

          <div class="input-icon-container">
            <span class="icon-svg">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-envelope-fill" viewBox="0 0 16 16">
                <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z"/>
              </svg>
            </span>
            <%= f.email_field :email, 
              autocomplete: "email", 
              placeholder: "ejemplo@hotmail.com", 
              class: "input-field", 
              id: "login-email" %>
          </div>
      </div>
      <button type="submit" class="btn-primary btn-small-text">
        Enviarme instrucciones para restaurar contraseña
      </button>
    <% end %>

    <div class="links">
      <%= link_to "Iniciar sesión", new_user_session_path, class: "link-text" %>
      <%= link_to "Registrarme", new_user_registration_path, class: "link-text" %>
    </div>
  </div>
</div>
