<div class="login-background"></div>

<div class="login-wrapper">

  <div class="login-card">

    <div class="logo-container">
      <%= image_tag "TuguyPora_logo.png", class: "logo-img" %>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "login-form" }) do |f| %>

      <!-- Email -->
      <div class="input-group">
        <label class="input-label">Correo electrónico</label>

        <div class="input-icon-container">
          <span class="icon-svg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-envelope-fill" viewBox="0 0 16 16">
              <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z"/>
            </svg>
          </span>
          <%= f.email_field :email, 
            autocomplete: "email", 
            placeholder: "ejemplo@hotmail.com", 
            class: "input-field", 
            id: "login-email" %>
        </div>
      </div>

      <!-- Password -->
      <div class="input-group">
        <label class="input-label">Contraseña</label>

        <div class="input-icon-container">
          <span class="icon-svg">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-lock-fill" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M8 0a4 4 0 0 1 4 4v2.05a2.5 2.5 0 0 1 2 2.45v5a2.5 2.5 0 0 1-2.5 2.5h-7A2.5 2.5 0 0 1 2 13.5v-5a2.5 2.5 0 0 1 2-2.45V4a4 4 0 0 1 4-4m0 1a3 3 0 0 0-3 3v2h6V4a3 3 0 0 0-3-3"/>
          </svg>
          </span>
          <%= f.password_field :password, 
            autocomplete: "current-password", 
            placeholder: "**********", 
            class: "input-field", 
            id: "login-password" %>
          <span class="toggle-password">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="eye-icon" viewBox="0 0 16 16">
              <path d="m10.79 12.912-1.614-1.615a3.5 3.5 0 0 1-4.474-4.474l-2.06-2.06C.938 6.278 0 8 0 8s3 5.5 8 5.5a7 7 0 0 0 2.79-.588M5.21 3.088A7 7 0 0 1 8 2.5c5 0 8 5.5 8 5.5s-.939 1.721-2.641 3.238l-2.062-2.062a3.5 3.5 0 0 0-4.474-4.474z"/>
              <path d="M5.525 7.646a2.5 2.5 0 0 0 2.829 2.829zm4.95.708-2.829-2.83a2.5 2.5 0 0 1 2.829 2.829zm3.171 6-12-12 .708-.708 12 12z"/>
            </svg>
          </span>
        </div>
      </div>

      <button type="submit" class="btn-primary">Iniciar sesión</button>

    <% end %>

    <div class="links">
      <%= link_to "Olvidé mi contraseña", new_user_password_path, class: "link-text" %>
      <%= link_to "Registrarme", new_user_registration_path, class: "link-text" %>
    </div>

  </div>

</div>
