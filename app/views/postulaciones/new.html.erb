<h1>Nueva Postulación</h1>

<%= form_with model: @postulacion, local: true do |f| %>
  <!-- Si vino desde una ubicación, se guarda el ubicacion_id -->
  <% if params[:ubicacion_id].present? %>
    <%= f.hidden_field :ubicacion_id, value: params[:ubicacion_id] %>
    <p><strong>Ubicación seleccionada:</strong> <%= Ubicacion.find(params[:ubicacion_id]).nombre %></p>
  <% else %>
    <div>
      <%= f.label :ubicacion_id, "Seleccionar punto de donación" %><br>
      <%= f.collection_select :ubicacion_id, Ubicacion.all, :id, :nombre, prompt: "Selecciona una ubicación" %>
    </div>
  <% end %>

  <!-- Si vino desde una solicitud, se guarda el solicitud_id -->
  <% if @solicitud.present? %>
    <%= f.hidden_field :solicitud_id, value: @solicitud.id %>
    <p><strong>Postulando para paciente:</strong> <%= @solicitud.nombre_paciente %></p>
  <% end %>

  <div>
    <%= f.label :fecha_tentativa, "Fecha Tentativa" %><br>
    <%= f.date_field :fecha_tentativa, min: Date.today %>
  </div>

  <div>
    <%= f.label :hora_tentativa, "Hora Tentativa" %><br>

    <%= f.select :hora_tentativa_hour,
      (07..18).map { |h| ["#{h.to_s.rjust(2, '0')}", h] },
      prompt: "Hora" %>

    <%= f.select :hora_tentativa_minute,
      [["00", 0], ["15", 15], ["30", 30], ["45", 45]],
      prompt: "Minuto" %>
  </div>

  <div style="margin-top: 20px;">
    <%= f.submit "Enviar Postulación", class: "btn btn-primary" %>
  </div>
<% end %>
