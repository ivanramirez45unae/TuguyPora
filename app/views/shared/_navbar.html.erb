<nav class="main-nav" role="navigation" aria-label="Main Navigation">
  <div class="nav-left">
    <%= link_to image_tag("tuguy_pora_horizontal.png", alt: "Tuguy Porã", class: "nav-logo"), root_path %>
  </div>

  <div class="nav-center">
    <% nav_items = if current_user&.centro?
      [
        ["Postulaciones", centros_dashboard_path],
        ["Donaciones", donaciones_path],
        ["Solicitudes", solicitudes_path],
        ["Donantes", donantes_path]
      ]
    else
      [
        ["Inicio", users_dashboard_path],
        ["Información y requisitos", informacion_path],
        ["Solicitudes", solicitudes_path]
      ]
    end %>

    <% nav_items.each do |label, path| %>
      <% active = current_page?(path) %>
      <%= link_to label, path, class: "nav-link #{'active' if active}" %>
    <% end %>
  </div>

  <div class="nav-right">
    <% if current_user %>
      <div class="nav-profile-wrapper">
        <% avatar_active = ["users", "centros"].include?(controller_name) %>

        <div class="nav-avatar <%= 'active' if avatar_active || current_page?(mi_perfil_path) || current_page?(centros_perfil_path) %>" id="avatarDropdownToggle">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "avatar-img" %>
          <% else %>
            <%= image_tag "default-avatar.png", class: "avatar-img" %>
          <% end %>
        </div>

        <!-- Dropdown: ID exacto -->
        <div class="nav-dropdown" id="avatarDropdown">
          <%= link_to "Mi perfil",
            (current_user.rol == "centro" ? centros_perfil_path : mi_perfil_path),
            class: "dropdown-item" %>

          <%= button_to destroy_user_session_path, method: :delete,
                data: { turbo: false, confirm: "¿Está seguro de que quiere cerrar sesión?" },
                class: "dropdown-item dropdown-logout" do %>
            Cerrar sesión
          <% end %>
        </div>
      </div>
    <% else %>
      <%= link_to "Ingresar", new_user_session_path, class: "nav-link login-link" %>
    <% end %>
  </div>
</nav>
