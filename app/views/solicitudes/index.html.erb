<%= render 'shared/navbar' %>

<h1 style="text-align: center; color: #c00000; margin-bottom: 30px;">🩸 Solicitudes de Sangre</h1>

<div style="text-align: center; margin-bottom: 30px;">
  <%= link_to '➕ Crear nueva solicitud', new_solicitud_path, class: "btn btn-danger", style: "padding: 12px 24px; font-weight: bold;" %>
</div>

<% if @solicitudes.any? %>
  <div class="solicitudes-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 20px;">
    <% @solicitudes.each do |solicitud| %>
      <% postulaciones_count = solicitud.postulaciones.count rescue 0 %>
      <% donaciones_confirmadas = solicitud.donaciones.count rescue 0 %>

      <div style="background: #fff; border: 1px solid #ddd; border-radius: 12px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.06); position: relative;">

        <!-- Publicado por -->
        <p style="font-size: 13px; color: #999; margin-bottom: 12px;">
          📢 <strong><%= solicitud.user.nombre %></strong> publicó esta solicitud
        </p>

        <h3 style="margin-top: 0; color: #c00000;"><%= solicitud.nombre_paciente %></h3>
        <p><strong>🆔 C.I.N.:</strong> <%= solicitud.cin_paciente %></p>
        <p><strong>💉 Tipo de Sangre:</strong> <%= solicitud.tipo_sangre %></p>
        <p><strong>📍 Ubicación:</strong> <%= solicitud.ubicacion.nombre %></p>
        <p><strong>🧑‍🤝‍🧑 Donantes requeridos:</strong> <%= solicitud.donantes_requeridos %></p>
        <p><strong>📝 Detalles:</strong> <%= solicitud.detalles.presence || "Sin detalles adicionales" %></p>

        <!-- Estado -->
        <p style="margin-top: 15px;">
          🔄 <strong>Estado:</strong>
          <% if donaciones_confirmadas > 0 || postulaciones_count > 0 %>
            <% if donaciones_confirmadas > 0 %>
              <%= pluralize(donaciones_confirmadas, 'donación', 'donaciones') %>
            <% end %>
            <% if donaciones_confirmadas > 0 && postulaciones_count > 0 %> y <% end %>
            <% if postulaciones_count > 0 %>
              <%= pluralize(postulaciones_count, 'postulación', 'postulaciones') %>
            <% end %>
          <% else %>
            <em>0 postulaciones</em>
          <% end %>
        </p>

        <!-- Acciones -->
        <div style="margin-top: 20px;">
          <% if solicitud.user == current_user %>
            <%= link_to '✏️ Editar', edit_solicitud_path(solicitud), class: 'btn btn-outline-primary', style: 'margin-right: 10px;' %>
            <%= button_to '🗑️ Eliminar', solicitud_path(solicitud), method: :delete,
                  form: { data: { confirm: '¿Estás seguro que deseas eliminar esta solicitud?' } },
                  class: 'btn btn-outline-danger' %>
          <% else %>
            <% if current_user&.donante %>
              <%= link_to '🤝 Donar', new_postulacion_path(solicitud_id: solicitud.id), class: 'btn btn-success' %>
            <% else %>
              <%= link_to 'Registrarse como donante', new_donante_path, class: 'btn btn-warning' %>
              <p class="text-danger mt-2">⚠️ Debes ser donante para postularte.</p>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p style="text-align: center; font-size: 18px; color: #777;">No hay solicitudes aún.</p>
<% end %>
