<%= render 'shared/navbar' %>

<h1 style="text-align: center; color: #c00000; margin-bottom: 30px;">🩸 Lista de Donantes</h1>

<% if @donantes.any? %>
  <div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; background: #fff; box-shadow: 0 4px 8px rgba(0,0,0,0.05);">
      <thead style="background-color: #37474F; color: white;">
        <tr>
          <th style="padding: 12px;">Nombre</th>
          <th style="padding: 12px;">Tipo de Sangre</th>
          <th style="padding: 12px;">Peso (kg)</th>
          <th style="padding: 12px;">Estatura (cm)</th>
          <th style="padding: 12px;">¿Tatuajes?</th>
          <th style="padding: 12px;">Última Donación</th>
          <th style="padding: 12px;">Verificación</th>
          <th style="padding: 12px;">Condiciones Crónicas</th>
          <th style="padding: 12px;">Medicamentos</th>
        </tr>
      </thead>
      <tbody>
        <% @donantes.each do |donante| %>
          <tr style="text-align: center; border-top: 1px solid #eee;">
            <td style="padding: 12px;"><%= donante.user.nombre %></td>
            <td style="padding: 12px;"><%= donante.tipo_sanguineo %></td>
            <td style="padding: 12px;"><%= donante.peso_kg %></td>
            <td style="padding: 12px;"><%= donante.estatura_cm %></td>
            <td style="padding: 12px;"><%= donante.tiene_tatuajes ? "Sí" : "No" %></td>
            <td style="padding: 12px;">
              <% if donante.ult_donacion_fecha.present? %>
                <%= l(donante.ult_donacion_fecha, format: :long) %>
              <% else %>
                <span style="color: #888;">Nunca</span>
              <% end %>
            </td>
            <td style="padding: 12px;">
              <% if donante.ult_donacion_fecha.present? %>
                <% if donante.ult_donacion_verificado %>
                  <span style="color: green;">Sí</span>
                <% else %>
                  <span style="color: orange;">No</span>
                <% end %>
              <% else %>
                —
              <% end %>
            </td>

            <!-- Condiciones Crónicas -->
            <td style="padding: 12px;">
              <% if donante.condiciones_cronicas.any? %>
                <ul style="text-align: left; padding-left: 16px; margin: 0;">
                  <% donante.condiciones_cronicas.each do |cond| %>
                    <li><%= cond.nombre %></li>
                  <% end %>
                </ul>
              <% else %>
                <span style="color: #888;">Ninguna</span>
              <% end %>
            </td>

            <!-- Medicamentos -->
            <td style="padding: 12px;">
              <% if donante.medicamentos.any? %>
                <ul style="text-align: left; padding-left: 16px; margin: 0;">
                  <% donante.medicamentos.each do |med| %>
                    <li><%= med.nombre %></li>
                  <% end %>
                </ul>
              <% else %>
                <span style="color: #888;">Ninguno</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p style="text-align: center; font-size: 18px; color: #777;">No hay donantes registrados aún.</p>
<% end %>
