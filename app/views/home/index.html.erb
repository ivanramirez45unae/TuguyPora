<%= render 'shared/navbar' %>

<h1>Puntos de Donación - Itapúa</h1>

<div style="display: flex; flex-wrap: wrap; gap: 20px;">
  <% @ubicaciones.each do |u| %>
    <div style="border: 1px solid #ccc; border-radius: 10px; padding: 15px; width: 250px; background-color: #f9f9f9;">
      <h3><%= u.nombre %></h3>
      <button onclick="document.getElementById('info-<%= u.id %>').style.display = (document.getElementById('info-<%= u.id %>').style.display == 'none' ? 'block' : 'none')" style="margin-top: 10px;">Ver más</button>
      <%= link_to "Donar", new_postulacion_path(location_id: u.id), style: "margin-top: 10px; display: inline-block; padding: 8px 15px; text-decoration: none; border: 1px solid #ccc;" %>
      <div id="info-<%= u.id %>" style="display: none; margin-top: 10px;">
        <p><strong>Dirección:</strong> <%= u.direccion %></p>
        <p><strong>Teléfono:</strong> <%= u.num_telefono %></p>
        <p><strong>Horario:</strong> <%=  %></p>
      </div>
    </div>
  <% end %>
</div>
