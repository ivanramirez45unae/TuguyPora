<%= render 'shared/navbar' %>

<div class="home-container">
  <div class="home-header">
    <h1>Puntos de donación</h1>

    <div class="search-container">
      <div class="search-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
             class="bi bi-search search-icon" viewBox="0 0 16 16">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
        </svg>

        <input type="text" placeholder="Buscar punto de donación"
               class="search-input" id="search-ubicacion" autocomplete="off">
      </div>
    </div>
  </div>

  <!-- Contenedor de la cuadrícula -->
  <div class="locations-grid" id="grid-container">
    <% @ubicaciones.where(activo: true).each do |u| %>
      <div class="location-card">
        <div class="location-image-wrapper">
        <%= image_tag(u.imagen.present? ? u.imagen : "placeholder.jpg", class: "location-image") %>
        <% 
          datos_horarios = u.horarios.joins(:dia).order('dias.id').map { |h| 
            { 
              dia: h.dia.nombre, 
              horas: "#{h.abre_a.strftime('%H:%M')} - #{h.cierra_a.strftime('%H:%M')}" 
            } 
          }.to_json
        %>
        <%= link_to "Ver detalles", "#", 
          class: "details-btn small-text", 
          data: { 
            nombre: u.nombre,
            direccion: u.direccion,
            telefono: u.num_telefono,
            imagen: (u.imagen.present? ? asset_path(u.imagen) : asset_path("placeholder.jpg")),
            url_donar: new_postulacion_path(ubicacion_id: u.id),
            horarios: datos_horarios 
          } 
        %>
      </div>

        <div class="card-body">
          <h3><%= u.nombre %></h3>

          <% if current_user&.donante %>
            <% # CASO 1: EL USUARIO YA ES DONANTE %>
            <%= link_to new_postulacion_path(ubicacion_id: u.id),
                        class: "donar-btn btn-primary btn-small-text" do %>
              <span class="donar-content">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                    fill="currentColor" class="bi bi-droplet-fill"
                    viewBox="0 0 16 16">
                  <path d="M8 16a6 6 0 0 0 6-6c0-1.655-1.122-2.904-2.432-4.362C10.254 4.176 8.75 2.503 8 0c0 0-6 5.686-6 10a6 6 0 0 0 6 6M6.646 4.646l.708.708c-.29.29-1.128 1.311-1.907 2.87l-.894-.448c.82-1.641 1.717-2.753 2.093-3.13"/>
                </svg>
                <span>Donar</span>
              </span>
            <% end %>

          <% else %>
            <% # CASO 2: EL USUARIO NO ES DONANTE %>
            <p class="alert-msg" style="margin-bottom: 10px; font-size: 13px; color: #666;">
              Debes registrarte como donante para postularte.
            </p>
            
            <%= link_to new_donante_path,
                        class: "donar-btn btn-primary btn-small-text", 
                        style: "background-color: #666;" do %>
              <span class="donar-content">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-plus-fill" viewBox="0 0 16 16">
                  <path d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                  <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5"/>
                </svg>
                <span>Registrarme como donante</span>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Mensaje de "No resultados" (oculto por defecto) -->
  <div id="no-results" class="no-results-container" style="display: none;">
    <div class="empty-state">
      <p>No encontramos ninguna ubicación con ese nombre.</p>
      <button id="clear-search" class="btn-clean">Ver todas</button>
    </div>
  </div>
</div>

<!-- ESTILOS EXTRA para la animación y el mensaje -->
<style>
  /* Animación: Corta y sutil */
  @keyframes fadeInCard {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .location-card {
    /* Mantiene la transición suave si algo cambia de tamaño */
    transition: all 0.2s ease;
  }

  .animate-appear {
    /* 0.3s es lo suficientemente rápido para no sentirse lento */
    animation: fadeInCard 0.3s ease-out forwards;
  }

  /* El resto de tus estilos del mensaje de error... */
  .no-results-container {
    text-align: center;
    padding: 40px 20px;
    width: 100%;
  }
  .empty-state p { font-size: 1.1rem; color: #666; margin-bottom: 10px; }
  .btn-clean { background: none; border: none; color: #121314ff; text-decoration: underline; cursor: pointer; }
</style>

  <!-- La ventana Modal -->
  <div id="modal-overlay" class="modal-overlay">
    <div class="modal-content">
      <span class="close-modal" onclick="closeModal()">&times;</span>
      
      <div class="modal-layout">
        <!-- COLUMNA IZQUIERDA: Imagen -->
        <div class="modal-image-col">
          <img id="modal-img" src="" alt="Foto del lugar">
        </div>
        
        <!-- COLUMNA DERECHA: Información -->
        <div class="modal-info-col">
          <h2 id="modal-title" class="modal-title"></h2>
          
          <!-- Horario (Como no está en tu DB, lo he dejado estático o podrías agregarlo a tu modelo) -->
          <div class="info-block">
            <h3 class="info-label">Horario de atención</h3>
            <!-- Contenedor vacío donde JS pondrá los datos -->
            <div id="modal-horarios-list" class="info-text">
                <!-- Aquí se generarán las líneas dinámicamente -->
            </div>
          </div>

          <!-- Dirección -->
          <div class="info-block">
            <h3 class="info-label">Dirección</h3>
            <p id="modal-direccion" class="info-text"></p>
          </div>

          <!-- Teléfono -->
          <div class="info-block">
            <h3 class="info-label">Teléfono</h3>
            <p id="modal-telefono" class="info-text"></p>
          </div>

          <!-- Botón de acción dentro del Modal -->
          <div class="modal-actions">
            <% if current_user&.donante %>
              <!-- CASO 1: ES DONANTE - Se muestra el botón de Donar (el JS actualizará el href) -->
              <a href="#" id="modal-btn-donar" class="donar-btn btn-primary btn-small-text">
                  <span class="donar-content">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                          fill="currentColor" class="bi bi-droplet-fill"
                          viewBox="0 0 16 16">
                        <path d="M8 16a6 6 0 0 0 6-6c0-1.655-1.122-2.904-2.432-4.362C10.254 4.176 8.75 2.503 8 0c0 0-6 5.686-6 10a6 6 0 0 0 6 6M6.646 4.646l.708.708c-.29.29-1.128 1.311-1.907 2.87l-.894-.448c.82-1.641 1.717-2.753 2.093-3.13"/>
                      </svg>
                      <span>Donar</span>
                  </span>
              </a>
            <% else %>
              <!-- CASO 2: NO ES DONANTE - Se muestra el botón gris de Registro -->
              <%= link_to new_donante_path, 
                    class: 'class="donar-btn btn-primary btn-small-text"', 
                    style: 'background-color: #666 !important; display: flex; align-items: center; justify-content: center; margin: 0 auto; width: fit-content; text-decoration: none; gap: 8px; padding: 10px 20px;' do %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-plus-fill" viewBox="0 0 16 16">
                      <path d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                      <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5"/>
                    </svg>
                    Registrarme como donante
                  <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // ==========================================
    // 1. BARRA DE BÚSQUEDA
    // ==========================================
    const searchInput = document.getElementById('search-ubicacion');
    const cards = document.querySelectorAll('.location-card');
    const noResults = document.getElementById('no-results');
    const clearBtn = document.getElementById('clear-search');

    if (searchInput) {
      const filterCards = (searchTerm) => {
        let visibleCount = 0;
        cards.forEach((card) => {
          const title = card.querySelector('h3').textContent.toLowerCase();
          const isMatch = title.includes(searchTerm);
          const isHidden = card.style.display === 'none';

          if (isMatch) {
            if (isHidden) {
              card.style.display = ''; 
              card.classList.remove('animate-appear');
              void card.offsetWidth; 
              card.classList.add('animate-appear');
            }
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (visibleCount === 0) {
          if (noResults.style.display === 'none') {
              noResults.style.display = 'block';
              noResults.classList.remove('animate-appear');
              void noResults.offsetWidth;
              noResults.classList.add('animate-appear');
          }
        } else {
          noResults.style.display = 'none';
        }
      };

      searchInput.addEventListener('input', (e) => {
        filterCards(e.target.value.toLowerCase().trim());
      });

      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        filterCards('');
        searchInput.focus();
      });
    }

    // ==========================================
    // 2. VENTANA MODAL
    // ==========================================
    
    const modal = document.getElementById('modal-overlay');
    const modalImg = document.getElementById('modal-img');
    const modalTitle = document.getElementById('modal-title');
    const modalDir = document.getElementById('modal-direccion');
    const modalTel = document.getElementById('modal-telefono');
    const modalBtnDonar = document.getElementById('modal-btn-donar');
    const listaHorarios = document.getElementById('modal-horarios-list');

    // Función para abrir modal
    const openModal = (data) => {
      modalImg.src = data.imagen;
      modalTitle.textContent = data.nombre;
      modalDir.textContent = data.direccion;
      modalTel.textContent = data.num_telefono;
      
      if (modalBtnDonar) modalBtnDonar.href = data.url_donar;

      // Renderizar Horarios
      listaHorarios.innerHTML = ''; 
      if (data.horarios && data.horarios.length > 0) {
        data.horarios.forEach(h => {
          const p = document.createElement('p');
          p.style.margin = "0 0 5px 0";
          p.innerHTML = `<span class="underline">${h.dia}:</span> ${h.horas} hs.`;
          listaHorarios.appendChild(p);
        });
      } else {
        listaHorarios.innerHTML = '<p>No hay horarios registrados.</p>';
      }

      modal.classList.add('active');
    };

    // Función para cerrar modal
    const closeModal = () => {
      modal.classList.remove('active');
    };

    // Exponer closeModal al objeto window por si usas onclick="closeModal()" en el HTML
    window.closeModal = closeModal; 

    // Listeners botones "Ver detalles"
    document.querySelectorAll('.details-btn').forEach(boton => {
      boton.addEventListener('click', function(e) {
        e.preventDefault();
        const datos = {
          nombre: this.dataset.nombre,
          direccion: this.dataset.direccion,
          num_telefono: this.dataset.telefono,
          imagen: this.dataset.imagen,
          url_donar: this.dataset.urlDonar,
          horarios: JSON.parse(this.dataset.horarios || "[]") 
        };
        openModal(datos);
      });
    });

    // Cerrar click afuera
    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === this) closeModal();
      });
    }
  });
</script>