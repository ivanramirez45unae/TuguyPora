<%= render 'shared/navbar' %>

<div class="home-container">
  <div class="home-header">
    <h1>Puntos de donación</h1>

    <div class="search-container">
      <div class="search-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
             class="bi bi-search search-icon" viewBox="0 0 16 16">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
        </svg>

        <input type="text" placeholder="Buscar punto de donación"
               class="search-input" id="search-ubicacion" autocomplete="off">
      </div>
    </div>
  </div>

  <!-- Contenedor de la cuadrícula -->
  <div class="locations-grid" id="grid-container">
    <% @ubicaciones.where(activo: true).each do |u| %>
      <div class="location-card">
        <div class="location-image-wrapper">
          <%= image_tag(u.imagen.present? ? u.imagen : "placeholder.jpg",
                        class: "location-image") %>
          <%= link_to "Ver detalles", "#", class: "details-btn small-text" %>
        </div>

        <div class="card-body">
          <h3><%= u.nombre %></h3>

          <% if current_user&.donante %>
            <%= link_to new_postulacion_path(ubicacion_id: u.id),
                        class: "donar-btn btn-primary btn-small-text" do %>
              <span class="donar-content">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     fill="currentColor" class="bi bi-droplet-fill"
                     viewBox="0 0 16 16">
                  <path d="M8 16a6 6 0 0 0 6-6c0-1.655-1.122-2.904-2.432-4.362C10.254 4.176 8.75 2.503 8 0c0 0-6 5.686-6 10a6 6 0 0 0 6 6M6.646 4.646l.708.708c-.29.29-1.128 1.311-1.907 2.87l-.894-.448c.82-1.641 1.717-2.753 2.093-3.13"/>
                </svg>
                <span>Donar</span>
              </span>
            <% end %>
          <% end %>

          <% unless current_user&.donante %>
            <p class="alert-msg">⚠️ Debes registrarte como donante.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Mensaje de "No resultados" (oculto por defecto) -->
  <div id="no-results" class="no-results-container" style="display: none;">
    <div class="empty-state">
      <p>No encontramos ninguna ubicación con ese nombre.</p>
      <button id="clear-search" class="btn-clean">Ver todas</button>
    </div>
  </div>
</div>

<!-- ESTILOS EXTRA para la animación y el mensaje -->
<style>
  /* Animación: Corta y sutil */
  @keyframes fadeInCard {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .location-card {
    /* Mantiene la transición suave si algo cambia de tamaño */
    transition: all 0.2s ease;
  }

  .animate-appear {
    /* 0.3s es lo suficientemente rápido para no sentirse lento */
    animation: fadeInCard 0.3s ease-out forwards;
  }

  /* El resto de tus estilos del mensaje de error... */
  .no-results-container {
    text-align: center;
    padding: 40px 20px;
    width: 100%;
  }
  .empty-state p { font-size: 1.1rem; color: #666; margin-bottom: 10px; }
  .btn-clean { background: none; border: none; color: #121314ff; text-decoration: underline; cursor: pointer; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-ubicacion');
    const cards = document.querySelectorAll('.location-card');
    const noResults = document.getElementById('no-results');
    const clearBtn = document.getElementById('clear-search');

    const filterCards = (searchTerm) => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const title = card.querySelector('h3').textContent.toLowerCase();
        const isMatch = title.includes(searchTerm);
        
        // Verificamos si la tarjeta está actualmente oculta o visible
        const isHidden = card.style.display === 'none';

        if (isMatch) {
          // CASO 1: Coincide y estaba oculta -> LA MOSTRAMOS Y ANIMAMOS
          if (isHidden) {
            card.style.display = ''; 
            card.classList.remove('animate-appear');
            void card.offsetWidth; // Reinicia la animación
            card.classList.add('animate-appear');
          }
          // CASO 2: Coincide y ya estaba visible -> NO HACEMOS NADA (así no parpadea)
          
          visibleCount++;
        } else {
          // CASO 3: No coincide -> OCULTAR
          card.style.display = 'none';
        }
      });

      // Lógica del mensaje "No resultados"
      if (visibleCount === 0) {
        if (noResults.style.display === 'none') {
            noResults.style.display = 'block';
            noResults.classList.remove('animate-appear');
            void noResults.offsetWidth;
            noResults.classList.add('animate-appear');
        }
      } else {
        noResults.style.display = 'none';
      }
    };

    searchInput.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase().trim();
      filterCards(term);
    });

    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      filterCards('');
      searchInput.focus();
    });
  });
</script>